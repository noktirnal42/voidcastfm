{
  "name": "voidcastfm",
  "version": "1.0.0",
  "description": "VoidCastFM — SDR Transmitter Control Station",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "app": "vite build && electron ."
  },
  "keywords": ["sdr", "radio", "transmitter", "raspberry-pi", "rf"],
  "author": "VoidCastFM Team",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "svelte": "^5.0.0",
    "svelte-routing": "^2.6.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "svelte-check": "^4.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.voidcastfm.app",
    "productName": "VoidCastFM",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "public/voidcast-icon.png"
    },
    "dmg": {
      "contents": [
        {
          "x": 110,
          "y": 150
        },
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
